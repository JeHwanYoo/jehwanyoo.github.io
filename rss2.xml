    <item>
      <title>DOM API 핵심 요약 정리</title>
      <link>https://jehwanyoo.net/2021/09/03/DOM-API-%ED%95%B5%EC%8B%AC-%EC%9A%94%EC%95%BD-%EC%A0%95%EB%A6%AC/</link>
